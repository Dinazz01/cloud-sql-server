locals {
  instance_name = var.instance_name

  default_flags = {
    slow_query_log     = "on"
    log_output         = "FILE"
    general_log        = "off"
    local_infile       = "off"
    skip_show_database = "on"
  }

  flags = merge(local.default_flags, var.flags)
}

resource "google_sql_database_instance" "this" {
  name             = local.instance_name
  project          = var.project_id
  region           = var.region
  database_version = var.database_version

  deletion_protection = var.deletion_protection
  root_password       = var.root_password_secret != null ? data.google_secret_manager_secret_version.root_password[0].secret_data : random_password.root_password[0].result

  settings {
    tier              = var.tier
    edition           = var.edition
    availability_type = var.availability_type
    disk_size         = var.disk_size
    disk_type         = var.disk_type
    disk_autoresize   = var.disk_autoresize
    user_labels       = var.labels

    ip_configuration {
      ipv4_enabled = var.ipv4_enabled
      ssl_mode     = var.ssl_mode

      dynamic "psc_config" {
        for_each = var.psc_config == null ? [] : [var.psc_config]
        content {
          psc_enabled               = true
          allowed_consumer_projects = psc_config.value.allowed_consumer_projects
        }
      }
    }

    backup_configuration {
      enabled                        = var.backup_config.enabled
      start_time                     = var.backup_config.start_time
      binary_log_enabled             = var.backup_config.point_in_time_recovery_enabled
      point_in_time_recovery_enabled = false

      backup_retention_settings {
        retained_backups = var.backup_config.retained_backups
        retention_unit   = var.backup_config.retention_unit
      }
    }

    dynamic "database_flags" {
      for_each = local.flags
      content {
        name  = database_flags.key
        value = database_flags.value
      }
    }

    dynamic "maintenance_window" {
      for_each = var.maintenance_window.enabled ? [var.maintenance_window] : []
      content {
        day          = maintenance_window.value.day
        hour         = maintenance_window.value.hour
        update_track = maintenance_window.value.update_track
      }
    }
  }
}

resource "random_password" "root_password" {
  count   = var.root_password_secret == null ? 1 : 0
  length  = 16
  special = true
  upper   = true
  lower   = true
  numeric = true
}

data "google_secret_manager_secret_version" "root_password" {
  count   = var.root_password_secret != null ? 1 : 0
  secret  = var.root_password_secret
  project = var.project_id
}

resource "google_sql_database" "databases" {
  for_each = var.databases

  project  = var.project_id
  instance = google_sql_database_instance.this.name
  name     = each.value.name
  charset  = try(each.value.charset, null)
  collation = try(each.value.collation, null)

  depends_on = [google_sql_database_instance.this]
}

data "google_secret_manager_secret_version" "user_passwords" {
  for_each = {
    for username, cfg in var.users : username => cfg
    if try(cfg.password_secret, null) != null
  }

  project = var.project_id
  secret  = each.value.password_secret
}

resource "random_password" "user_passwords" {
  for_each = {
    for username, cfg in var.users : username => cfg
    if try(cfg.password_secret, null) == null
  }

  length  = 16
  special = true
  upper   = true
  lower   = true
  numeric = true
}

