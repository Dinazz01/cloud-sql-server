locals {
  location_parts  = regex("^us-([a-z]+)([0-9]+)-([a-z])$", var.region)
  location_short  = "us${local.location_parts[1]}${local.location_parts[2]}${local.location_parts[3]}"

  base_name = "csql-${substr(var.environment, 0, 1)}-${local.location_short}-${var.platform}"

