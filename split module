variable "database_version" {
  type = string
}

variable "tier" {
  type = string
}

variable "edition" {
  type    = string
  default = "ENTERPRISE_PLUS"
}

variable "availability_type" {
  type    = string
  default = "ZONAL"

  validation {
    condition     = contains(["ZONAL", "REGIONAL"], var.availability_type)
    error_message = "availability_type must be ZONAL or REGIONAL."
  }
}

variable "disk_size" {
  type    = number
  default = 20
}

variable "disk_type" {
  type    = string
  default = "PD_SSD"
}

variable "disk_autoresize" {
  type    = bool
  default = true
}

variable "deletion_protection" {
  type    = bool
  default = false
}

variable "ipv4_enabled" {
  type    = bool
  default = false
}

variable "ssl_mode" {
  type    = string
  default = "ENCRYPTED_ONLY"
}

variable "root_password_secret" {
  type    = string
  default = null
}

variable "psc_config" {
  type = object({
    allowed_consumer_projects = list(string)
  })

  default = null
}

variable "backup_config" {
  type = object({
    enabled                        = bool
    start_time                     = string
    retained_backups               = number
    retention_unit                 = string
    point_in_time_recovery_enabled = optional(bool, false)
    transaction_log_retention_days = optional(number, null)
  })

  default = {
    enabled                        = true
    start_time                     = "03:00"
    retained_backups               = 14
    retention_unit                 = "COUNT"
    point_in_time_recovery_enabled = false
    transaction_log_retention_days = null
  }
}

variable "maintenance_window" {
  type = object({
    enabled      = bool
    day          = number
    hour         = number
    update_track = string
  })

  default = {
    enabled      = false
    day          = 7
    hour         = 3
    update_track = "stable"
  }
}

variable "databases" {
  type = map(object({
    name      = string
    charset   = optional(string)
    collation = optional(string)
  }))

  default = {}
}

variable "users" {
  type = map(object({
    password_secret = optional(string)
    type            = optional(string)
  }))

  default = {}
}

variable "flags" {
  type    = map(string)
  default = {}
}

variable "labels" {
  type    = map(string)
  default = {}
}
